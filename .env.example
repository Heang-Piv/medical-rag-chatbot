# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real API keys.

# --- Data & storage ---
DATA_FOLDER=data/medical
CHROMA_PERSIST_DIR=chroma_db

# --- Chunking ---
CHUNK_SIZE_TOKENS=350
CHUNK_OVERLAP_TOKENS=50

# --- Embeddings ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Retrieval ---
TOP_K_DEFAULT=4
SIMILARITY_THRESHOLD=0.5

# --- LLM generation ---
# Provider: anthropic | openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.0
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Leave blank to use OpenAI's own API. To use a free-tier OpenAI-compatible
# endpoint instead (e.g. NVIDIA's model catalog), set all three of:
#   LLM_PROVIDER=openai
#   LLM_MODEL=openai/gpt-oss-120b        # any model NVIDIA hosts
#   OPENAI_API_KEY=<your NVIDIA API key>  # from build.nvidia.com
#   OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_BASE_URL=

# --- Logging ---
LOG_LEVEL=INFO
